# GTA-Apple 环境配置
# 服务器只保留 run.sh 时，最关键的是设置 ALTSERVER_IMAGE

# 镜像拉取模式使用的 AltServer 镜像
ALTSERVER_IMAGE=

# 本地执行 ./run.sh push 时可选，用来推导镜像名
DOCKERHUB_USERNAME=

# 自建镜像底层系统版本
DEBIAN_RELEASE=trixie

# Anisette 绑定地址，默认仅本机访问
ANISETTE_BIND_ADDRESS=127.0.0.1

# Anisette v3 服务端口
ANISETTE_PORT=6969

# USBMUXD Socket 地址
USBMUXD_SOCKET_ADDRESS=host.docker.internal:27015

# GTA-Apple 环境配置
# 无参数执行 ./run.sh 时会自动加载本文件
# ALTSERVER_IMAGE 已在 run.sh 中内置默认值，如需改成其他仓库再取消注释

# ALTSERVER_IMAGE=aizhihuxiao/gta-altserver:latest

# 本地执行 ./run.sh push 时可选，用来推导镜像名
DOCKERHUB_USERNAME=

# 自建镜像底层系统版本
DEBIAN_RELEASE=trixie

# Anisette 绑定地址，默认仅本机访问
ANISETTE_BIND_ADDRESS=127.0.0.1

# Anisette v3 服务端口
ANISETTE_PORT=6969

# USBMUXD Socket 地址
USBMUXD_SOCKET_ADDRESS=host.docker.internal:27015

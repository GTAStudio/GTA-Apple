# GTA-Apple 环境配置
# ===========================================

# AltServer 镜像地址
ALTSERVER_IMAGE=yourusername/gta-altserver:latest

# Docker Hub 用户名 (用于本地 push)
DOCKERHUB_USERNAME=yourusername

# 自建镜像底层系统版本
DEBIAN_RELEASE=trixie

# Anisette v3 服务端口 (默认: 6969)
ANISETTE_PORT=6969

# USBMUXD Socket 地址
# 如果使用 WiFi 连接设备，设置为 netmuxd 地址
# 如果运行在宿主机上: host.docker.internal:27015
USBMUXD_SOCKET_ADDRESS=host.docker.internal:27015
